# Shared routing and transaction mode
# Valid TX_MODE values: 2pc, saga
TX_MODE=2pc

# Process sizing
ORDER_GUNICORN_WORKERS=2
STOCK_GUNICORN_WORKERS=1
PAYMENT_GUNICORN_WORKERS=1

# Benchmark runner
ORDER_REPLICAS=1
PAYMENT_REPLICAS=1
STOCK_REPLICAS=1
ORDER_DB_REPLICA_COUNT=1
PAYMENT_DB_REPLICA_COUNT=1
STOCK_DB_REPLICA_COUNT=1
SAGA_BROKER_REPLICA_COUNT=1
SENTINEL_REPLICAS=1

# Optional for minikube benchmarks when the gateway load balancer is not auto-detected
# BENCHMARK_GATEWAY_URL=
