# Lean local benchmark profile for an 8-core / 16 GB laptop.
# Use with:
#   docker compose --env-file .env.benchmark -f docker-compose.benchmark.yml up -d --build

# Host ports
DDS_GATEWAY_PORT=8000
DDS_FLUXI_SERVER_PORT=8001

# API process counts
ORDER_API_WORKERS=4
STOCK_API_WORKERS=1
PAYMENT_API_WORKERS=1

# Fluxi control plane
FLUXI_SERVER_WORKERS=3
FLUXI_RESULT_WAIT_TIMEOUT_MS=30000
DDS_TRACE_LOGGING=1
DDS_LOG_LEVEL=INFO

# Worker concurrency per container
FLUXI_ORDER_WORKFLOW_CONCURRENCY=2
FLUXI_ORDER_ACTIVITY_CONCURRENCY=1
FLUXI_STOCK_ACTIVITY_CONCURRENCY=4
FLUXI_PAYMENT_ACTIVITY_CONCURRENCY=4

# Fluxi HTTP client pooling
# This profile favors order-service admission capacity because the
# synchronous checkout path bottlenecks there before Fluxi saturates.
FLUXI_HTTP_CONNECT_TIMEOUT_SECONDS=5.0
FLUXI_HTTP_READ_TIMEOUT_SECONDS=15.0
FLUXI_HTTP_WRITE_TIMEOUT_SECONDS=15.0
FLUXI_HTTP_POOL_TIMEOUT_SECONDS=5.0
FLUXI_HTTP_MAX_CONNECTIONS=32
FLUXI_HTTP_MAX_KEEPALIVE_CONNECTIONS=16
FLUXI_HTTP_CONTROL_MAX_CONNECTIONS=192
FLUXI_HTTP_CONTROL_MAX_KEEPALIVE_CONNECTIONS=96
FLUXI_HTTP_RESULT_MAX_CONNECTIONS=192
FLUXI_HTTP_RESULT_MAX_KEEPALIVE_CONNECTIONS=96
